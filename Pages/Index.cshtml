@page
@model IndexModel
@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="text-center mt-5">
    <h1 class="display-4 text-primary" style="font-weight: 600;">Minik Adımlar Kreşine Hoş Geldiniz</h1>
    <p class="lead mt-3">Çocuklarınız için güvenli, eğlenceli ve öğretici bir yuva.</p>
</div>

<hr class="my-5" style="opacity: 0.1;" />

<div class="container">
    <h2 class="text-center mb-4" style="color: #5a5a5a;">Fotoğraf Galerimiz</h2>
    
    <div class="row">
        @if (Model.GalleryImages != null && Model.GalleryImages.Any())
        {
            // Veritabanından gelen her bir fotoğraf için bir kart oluşturuyoruz
            foreach (var item in Model.GalleryImages)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@item.ImagePath" class="card-img-top rounded" alt="Kreş Fotoğrafı" style="height: 250px; object-fit: cover;">
                        
                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            <div class="card-body py-2 text-center bg-light rounded-bottom">
                                <p class="card-text text-muted small mb-0">@item.Description</p>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted">
                <p>Yakında burası cıvıl cıvıl fotoğraflarla dolacak! 🎨</p>
            </div>
        }
    </div>
</div>