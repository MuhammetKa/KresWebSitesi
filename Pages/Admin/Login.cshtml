@page
@model KresWebSitesi.Pages.Admin.LoginModel
@{ ViewData["Title"] = "Yönetici Girişi"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4 card p-4 shadow-sm">
            <h3 class="text-center mb-4">Panel Girişi</h3>
            @if (!string.IsNullOrEmpty(Model.Message)) { <div class="alert alert-danger">@Model.Message</div> }
            <form method="post">
                <div class="mb-3"><input type="text" asp-for="Username" class="form-control" placeholder="Kullanıcı Adı" required></div>
                <div class="mb-3"><input type="password" asp-for="Password" class="form-control" placeholder="Şifre" required></div>
                <button type="submit" class="btn btn-primary w-100">Giriş Yap</button>
            </form>
        </div>
    </div>
</div>